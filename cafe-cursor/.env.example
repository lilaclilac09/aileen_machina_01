# ===========================================
# Cafe Cursor - Environment Variables
# ===========================================

# --- Database (required on Vercel: Postgres) ---
# Vercel Storage → Postgres usually gives you:
#   POSTGRES_PRISMA_URL  → paste as DATABASE_URL
#   POSTGRES_URL_NON_POOLING → paste as DIRECT_URL
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"
# Optional: if Neon/Vercel also gives an unpooled URL, you can set DIRECT_URL
# but it is not required by Prisma in this project anymore.
# DIRECT_URL="postgresql://user:password@host:5432/database?sslmode=require"

# --- Resend (can add AFTER site is live) ---
# 1) https://resend.com → API Keys
# 2) Domains → add aileena.xyz → copy DNS records to 腾讯云 DNSPod
# Until domain is verified, emails may only reach your own inbox.
RESEND_API_KEY="re_your_api_key_here"
FROM_EMAIL="Cafe Cursor Shanghai <cafe@aileena.xyz>"
# Must be an address on your Resend-verified domain (aileena.xyz).
# onboarding@resend.dev can ONLY email the Resend account owner — not guests.
# --- Admin (required — no defaults in code) ---
# Prefer hashed password (never commit the real password):
#   cd cafe-cursor && npx tsx scripts/hash-admin-password.ts 'your-new-strong-password'
ADMIN_USERNAME="admin"
# ADMIN_PASSWORD_HASH="scrypt$...."
# Or temporary plaintext (migrate to hash ASAP after any breach):
ADMIN_PASSWORD="your_secure_password_here"
# Long random string — rotating this logs everyone out:
SESSION_SECRET="change-me-to-a-long-random-string-at-least-32-chars"

# Private organizer inbox for encrypted Notify receipts (keep ONLY in Vercel):
# NOTIFY_CC_EMAIL="you@example.com"
# Optional dedicated encrypt key (else SESSION_SECRET is used):
# ORGANIZER_COPY_SECRET="long-random-string"
# Guests always Reply-To brand address (never personal Gmail):
# NOTIFY_REPLY_TO="cafe@aileena.xyz"

# --- IRL redeem (no Luma Plus needed) ---
# allowlist = only emails imported via Admin → Import Luma CSV (recommended)
# open      = any email + EVENT_CHECKIN_CODE (door code / QR)
# luma      = Luma API checked-in only (needs Luma Plus — skip if you don't have it)
REDEEM_MODE="allowlist"
# Special users (Admin → special user) may claim multiple credits:
# VOLUNTEER_MAX_CLAIMS="6"
# Only needed when REDEEM_MODE=open:
# EVENT_CHECKIN_CODE="your_door_code"

# --- Luma API (optional, Luma Plus only) ---
# Without Plus: export Guests CSV from Luma → Admin → Import Luma CSV
# LUMA_API_KEY="luma_xxxxxxxx"
# LUMA_EVENT_ID="evt-xxxxxxxx"

# --- Public URL (QR) ---
NEXT_PUBLIC_SITE_URL="https://cursor-cafe.aileena.xyz"

# --- Google Sheet credits (Admin Clear+Sync only; keep sheet private to your account) ---
# Source inventory sheet (import). Do NOT point this at an "Export available" CSV sheet
# unless you intentionally want Clear+Sync to replace the live unused pool from it.
GOOGLE_SHEET_CREDITS_ID="your_google_sheet_id_here"
