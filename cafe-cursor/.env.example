# ===========================================
# Cafe Cursor - Environment Variables
# ===========================================

# --- Database (required on Vercel: Postgres) ---
# Vercel Storage → Postgres usually gives you:
#   POSTGRES_PRISMA_URL  → paste as DATABASE_URL
#   POSTGRES_URL_NON_POOLING → paste as DIRECT_URL
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"
# Optional: if Neon/Vercel also gives an unpooled URL, you can set DIRECT_URL
# but it is not required by Prisma in this project anymore.
# DIRECT_URL="postgresql://user:password@host:5432/database?sslmode=require"

# --- Resend (can add AFTER site is live) ---
# 1) https://resend.com → API Keys
# 2) Domains → add aileena.xyz → copy DNS records to 腾讯云 DNSPod
# Until domain is verified, emails may only reach your own inbox.
RESEND_API_KEY="re_your_api_key_here"
FROM_EMAIL="Cafe Cursor Shanghai <onboarding@resend.dev>"
# After domain verify, prefer:
# FROM_EMAIL="Cafe Cursor Shanghai <cafe@aileena.xyz>"

# --- Admin ---
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="your_secure_password_here"
SESSION_SECRET="change-me-long-random-string"

# --- IRL redeem (no Luma Plus needed) ---
# allowlist = only emails imported via Admin → Import Luma CSV (recommended)
# open      = any email + EVENT_CHECKIN_CODE (door code / QR)
# luma      = Luma API checked-in only (needs Luma Plus — skip if you don't have it)
REDEEM_MODE="allowlist"
# Special users (Admin → special user) may claim multiple credits:
# VOLUNTEER_MAX_CLAIMS="6"
# Only needed when REDEEM_MODE=open:
# EVENT_CHECKIN_CODE="shanghai2026"

# --- Luma API (optional, Luma Plus only) ---
# Without Plus: export Guests CSV from Luma → Admin → Import Luma CSV
# LUMA_API_KEY="luma_xxxxxxxx"
# LUMA_EVENT_ID="evt-w2XLnrrLK1kWHNO"

# --- Public URL (QR) ---
NEXT_PUBLIC_SITE_URL="https://cursor-cafe.aileena.xyz"

# --- Google Sheet credits ---
GOOGLE_SHEET_CREDITS_ID="1STC2voXO53oWsfMqH3mdQMdf6xeTDw7gEQA0DGRZOik"
