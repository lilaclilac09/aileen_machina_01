# ===========================================
# Cafe Cursor - Environment Variables
# ===========================================

# Database (Vercel Postgres / Supabase / Neon)
# DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"
# DIRECT_URL="postgresql://user:password@host:5432/database?sslmode=require"

# Local development with SQLite:
DATABASE_URL="file:./dev.db"

# Resend Email Service (https://resend.com)
RESEND_API_KEY="re_your_api_key_here"
FROM_EMAIL="Cafe Cursor <onboarding@resend.dev>"

# Admin Panel Credentials
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="your_secure_password_here"
SESSION_SECRET="change-me-in-production"

# IRL redeem mode:
# - open: any unique email can claim once (after check-in code)
# - allowlist: only pre-approved EligibleUser emails
REDEEM_MODE="open"

# Venue code shown after door check-in (required when set)
EVENT_CHECKIN_CODE="shanghai2026"

# Public site URL used for QR links (set after deploy)
# NEXT_PUBLIC_SITE_URL="https://your-cafe-cursor.vercel.app"

# Google Sheet with Cursor referral links (one URL per row)
# Default: Cafe Cursor Shanghai - Aileen
GOOGLE_SHEET_CREDITS_ID="1STC2voXO53oWsfMqH3mdQMdf6xeTDw7gEQA0DGRZOik"
# Or full CSV export URL:
# GOOGLE_SHEET_CREDITS_CSV_URL="https://docs.google.com/spreadsheets/d/1STC2voXO53oWsfMqH3mdQMdf6xeTDw7gEQA0DGRZOik/export?format=csv"
