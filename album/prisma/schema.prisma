// Gather album — SQLite for local/MVP verify.
// Production (Vercel): switch provider to "postgresql" and set DATABASE_URL.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Album {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  adminSecretHash String
  expiresAt       DateTime
  uploadLocked    Boolean  @default(false)
  photoCount      Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  photos          Photo[]
}

model Photo {
  id           String    @id @default(cuid())
  albumId      String
  album        Album     @relation(fields: [albumId], references: [id], onDelete: Cascade)
  storageKey   String
  thumbKey     String
  url          String
  thumbUrl     String
  width        Int       @default(0)
  height       Int       @default(0)
  uploaderName String    @default("")
  caption      String    @default("")
  pinned       Boolean   @default(false)
  pinnedAt     DateTime?
  likeCount    Int       @default(0)
  createdAt    DateTime  @default(now())
  deletedAt    DateTime?
  likes        Like[]
  comments     Comment[]

  @@index([albumId, deletedAt, pinned, createdAt])
}

model Like {
  id         String   @id @default(cuid())
  photoId    String
  photo      Photo    @relation(fields: [photoId], references: [id], onDelete: Cascade)
  visitorKey String
  createdAt  DateTime @default(now())

  @@unique([photoId, visitorKey])
  @@index([photoId])
}

model Comment {
  id         String   @id @default(cuid())
  photoId    String
  photo      Photo    @relation(fields: [photoId], references: [id], onDelete: Cascade)
  authorName String
  body       String
  createdAt  DateTime @default(now())

  @@index([photoId, createdAt])
}
