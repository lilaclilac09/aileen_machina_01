# Gather / 共影
DATABASE_URL="file:./dev.db"
ADMIN_COOKIE_SECRET="dev-change-me-in-production"

# local | blob | r2 | dual
# dual = write Cloudflare R2 (intl) + 阿里云 OSS (CN), serve by geo
STORAGE_DRIVER="local"

# Vercel Blob (STORAGE_DRIVER=blob)
# BLOB_READ_WRITE_TOKEN=

# Cloudflare R2 (STORAGE_DRIVER=r2 or dual)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_PUBLIC_BASE_URL=https://media.example.com

# 阿里云 OSS (STORAGE_DRIVER=dual)
# OSS_REGION=oss-cn-hangzhou
# OSS_ACCESS_KEY_ID=
# OSS_ACCESS_KEY_SECRET=
# OSS_BUCKET=
# OSS_PUBLIC_BASE_URL=https://album-cn.example.com

NEXT_PUBLIC_APP_URL="http://localhost:3010"
